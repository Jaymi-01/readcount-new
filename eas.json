{
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "environment": "preview",
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "preInstall": "echo $GOOGLE_SERVICES_BASE64 | base64 -d > google-services.json"
    },
    "production": {
      "environment": "preview",
      "autoIncrement": true,
      "android": {
        "buildType": "apk"
      },
      "preInstall": "echo $GOOGLE_SERVICES_BASE64 | base64 -d > google-services.json"
    }
  },
  "submit": {
    "production": {}
  }
}