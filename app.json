{
  "expo": {
    "name": "Read Count",
    "slug": "readcount-new",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "readcountnew",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.jaymi.readcountnew"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#6366f1",
        "foregroundImage": "./assets/images/readcount2.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.jaymi.readcountnew",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/readcount2.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-secure-store",
      [
        "expo-widgets",
        {
          "widgets": [
            {
              "name": "ReadingProgress",
              "src": "./widgets/index.tsx",
              "description": "Shows your yearly reading progress",
              "minWidth": "100dp",
              "minHeight": "100dp"
            }
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0b6f0b91-e437-4571-902d-808344c56c11"
      }
    }
  }
}