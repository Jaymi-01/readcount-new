{
  "expo": {
    "name": "Read Count",
    "slug": "readcount-new",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "readcountnew",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.jaymi.readcountnew",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Allow Read Count to use Face ID to unlock your library."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#bc6c25",
        "foregroundImage": "./assets/images/readcount2.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.jaymi.readcountnew",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "updates": {
      "url": "https://u.expo.dev/0b6f0b91-e437-4571-902d-808344c56c11"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "plugins": [
      "expo-updates",
      "expo-router",
      "expo-notifications",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/readcount2.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0b6f0b91-e437-4571-902d-808344c56c11"
      }
    }
  }
}